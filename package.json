{
  "name": "fareping",
  "version": "1.0.0",
  "description": "FarePing flight price alert app",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "build:web": "expo export --platform web --output-dir dist",
    "build:pages": "npm run build:web && node scripts/prepare-gh-pages.mjs",
    "check": "expo install --check",
    "test:aviasales": "node scripts/test-aviasales-api.mjs"
  },
  "keywords": [
    "expo",
    "react-native",
    "travel",
    "flight-alerts",
    "portfolio"
  ],
  "author": "Hong",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "^56.0.12",
    "lucide-react-native": "^1.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  }
}
